    <!-- ── REF 1 : Kermack & McKendrick 1927 — Modèle SIR original ── -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Ref_KermackMcKendrick_1927">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#ModelReference"/>
        <rdfs:label>Kermack &amp; McKendrick (1927)</rdfs:label>
        <m2:hasAuthor>Kermack, W.O.; McKendrick, A.G.</m2:hasAuthor>
        <m2:hasPublicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1927</m2:hasPublicationYear>
        <m2:hasJournal>Proceedings of the Royal Society A</m2:hasJournal>
        <m2:hasDOI>10.1098/rspa.1927.0118</m2:hasDOI>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#SIR_General_KermackMcKendrick_1927">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#SIRModel"/>
        <rdfs:label xml:lang="fr">Modèle SIR — Kermack &amp; McKendrick (1927)</rdfs:label>
        <rdfs:label xml:lang="en">SIR Model — Kermack &amp; McKendrick (1927)</rdfs:label>
        <m2:hasFormalism rdf:resource="http://www.pacadi.org/these/piponto/module2#ODE_Formalism"/>
        <m2:hasReference rdf:resource="http://www.pacadi.org/these/piponto/module2#Ref_KermackMcKendrick_1927"/>
        <m2:hasTargetPopulation rdf:resource="http://www.pacadi.org/these/piponto/module2#Pop_General"/>
        <m2:hasValidatedScope rdf:resource="http://www.pacadi.org/these/piponto/module2#Scope_Global"/>
        <m2:hasExecutionPlatform rdf:resource="http://www.pacadi.org/these/piponto/module2#Python_Platform"/>
        <m2:isStochastic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</m2:isStochastic>
        <m2:hasQualityScore rdf:datatype="http://www.w3.org/2001/XMLSchema#double">1.0</m2:hasQualityScore>
        <m2:hasKeyword>SIR</m2:hasKeyword>
        <m2:hasKeyword>compartmental</m2:hasKeyword>
        <m2:hasKeyword>general population</m2:hasKeyword>
        <m2:hasKeyword>immunité permanente</m2:hasKeyword>
        <rdfs:comment>Modèle fondateur de l'épidémiologie mathématique. Immunité permanente.
        Paramètres : β (taux transmission), γ (taux guérison), R0 = β/γ.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ── REF 2 : Ferguson et al. 2020 — COVID-19 Imperial College ── -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Ref_Ferguson_2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#ModelReference"/>
        <rdfs:label>Ferguson et al. (2020) — Imperial College</rdfs:label>
        <m2:hasAuthor>Ferguson, N.; Laydon, D.; Nedjati-Gilani, G. et al.</m2:hasAuthor>
        <m2:hasPublicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2020</m2:hasPublicationYear>
        <m2:hasJournal>Imperial College COVID-19 Response Team — Report 9</m2:hasJournal>
        <m2:hasDOI>10.25561/77482</m2:hasDOI>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#SEIR_COVID_Ferguson_2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#SEIRModel"/>
        <rdfs:label xml:lang="fr">Modèle SEIR COVID-19 — Ferguson Imperial College (2020)</rdfs:label>
        <rdfs:label xml:lang="en">SEIR COVID-19 — Ferguson Imperial College (2020)</rdfs:label>
        <m2:hasFormalism rdf:resource="http://www.pacadi.org/these/piponto/module2#ODE_Formalism"/>
        <m2:hasReference rdf:resource="http://www.pacadi.org/these/piponto/module2#Ref_Ferguson_2020"/>
        <m2:hasTargetPopulation rdf:resource="http://www.pacadi.org/these/piponto/module2#Pop_General"/>
        <m2:hasValidatedScope rdf:resource="http://www.pacadi.org/these/piponto/module2#Scope_UK"/>
        <m2:hasValidatedScope rdf:resource="http://www.pacadi.org/these/piponto/module2#Scope_Global"/>
        <m2:hasExecutionPlatform rdf:resource="http://www.pacadi.org/these/piponto/module2#Python_Platform"/>
        <m2:isStochastic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</m2:isStochastic>
        <m2:hasQualityScore rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.97</m2:hasQualityScore>
        <m2:hasImplementationURI rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://github.com/mrc-ide/covid-sim</m2:hasImplementationURI>
        <m2:hasKeyword>COVID-19</m2:hasKeyword>
        <m2:hasKeyword>SEIR</m2:hasKeyword>
        <m2:hasKeyword>coronavirus</m2:hasKeyword>
        <m2:hasKeyword>SARS-CoV-2</m2:hasKeyword>
        <m2:hasKeyword>pandémie</m2:hasKeyword>
        <m2:hasKeyword>population générale</m2:hasKeyword>
        <rdfs:comment>Modèle de référence COVID-19. Paramètres publiés :
        R0=2.4, incubation=5.1j, infectiosité=2.9j.
        Validé UK et extrapolé mondialement. Très cité (10 000+ citations).</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ── REF 3 : Cauchemez et al. 2011 — COVID/grippe en milieu scolaire ── -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Ref_Cauchemez_2011">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#ModelReference"/>
        <rdfs:label>Cauchemez et al. (2011)</rdfs:label>
        <m2:hasAuthor>Cauchemez, S.; Bhattarai, A.; Marchbanks, T.L. et al.</m2:hasAuthor>
        <m2:hasPublicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2011</m2:hasPublicationYear>
        <m2:hasJournal>American Journal of Epidemiology</m2:hasJournal>
        <m2:hasDOI>10.1093/aje/kwq425</m2:hasDOI>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#SEIR_School_Cauchemez_2011">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#SEIRModel"/>
        <rdfs:label xml:lang="fr">Modèle SEIR transmission scolaire — Cauchemez (2011)</rdfs:label>
        <rdfs:label xml:lang="en">SEIR School Transmission — Cauchemez (2011)</rdfs:label>
        <m2:hasFormalism rdf:resource="http://www.pacadi.org/these/piponto/module2#ODE_Formalism"/>
        <m2:hasReference rdf:resource="http://www.pacadi.org/these/piponto/module2#Ref_Cauchemez_2011"/>
        <m2:hasTargetPopulation rdf:resource="http://www.pacadi.org/these/piponto/module2#Pop_School"/>
        <m2:hasValidatedScope rdf:resource="http://www.pacadi.org/these/piponto/module2#Scope_Global"/>
        <m2:hasExecutionPlatform rdf:resource="http://www.pacadi.org/these/piponto/module2#R_Platform"/>
        <m2:isStochastic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</m2:isStochastic>
        <m2:hasQualityScore rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.88</m2:hasQualityScore>
        <m2:hasKeyword>école</m2:hasKeyword>
        <m2:hasKeyword>écoliers</m2:hasKeyword>
        <m2:hasKeyword>enfants</m2:hasKeyword>
        <m2:hasKeyword>transmission scolaire</m2:hasKeyword>
        <m2:hasKeyword>milieu scolaire</m2:hasKeyword>
        <m2:hasKeyword>COVID-19</m2:hasKeyword>
        <m2:hasKeyword>grippe</m2:hasKeyword>
        <rdfs:comment>Modèle SEIR adapté au milieu scolaire. Taux de contact élevé entre élèves.
        β_école &gt; β_général. Inclut fermeture d'école comme intervention.
        Paramètres : R0_école ≈ 1.3 (grippe), β contact scolaire = 0.6/j.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ── REF 4 : Roux et al. 2020 — COVID-19 France ── -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Ref_Roux_2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#ModelReference"/>
