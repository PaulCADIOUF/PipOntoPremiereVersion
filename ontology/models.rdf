        <m2:hasKeyword>agents</m2:hasKeyword>
        <m2:hasKeyword>urbain</m2:hasKeyword>
        <m2:hasKeyword>Paris</m2:hasKeyword>
        <m2:hasKeyword>écoliers</m2:hasKeyword>
        <m2:hasKeyword>école</m2:hasKeyword>
        <m2:hasKeyword>spatial</m2:hasKeyword>
        <rdfs:comment>Covasim : ABM individu-centré COVID-19. Chaque agent a âge, statut, réseau de contacts.
        Gère : école, travail, domicile, transports. Idéal pour "écoliers à Paris".
        Calibré sur données de mobilité et démographie urbaine.</rdfs:comment>
    </owl:NamedIndividual>


    <!-- ══════════════════════════════════════════════════════════
         PARAMÈTRES PUBLIÉS PAR MODÈLE
         Valeurs tirées directement des articles — traçables et citables
         ══════════════════════════════════════════════════════════ -->

    <!-- Paramètres Ferguson 2020 (COVID-19 général) -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Param_Beta_Ferguson_2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#TransmissionRateParameter"/>
        <rdfs:label>β — Ferguson 2020</rdfs:label>
        <m2:hasParameterSymbol>β</m2:hasParameterSymbol>
        <m2:hasDefaultValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.429</m2:hasDefaultValue>
        <rdfs:comment>β = R0 × γ = 3.0 × (1/7) ≈ 0.429 /jour. Source : Ferguson et al. 2020.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Param_Sigma_Ferguson_2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#ModelParameter"/>
        <rdfs:label>σ — Ferguson 2020</rdfs:label>
        <m2:hasParameterSymbol>σ</m2:hasParameterSymbol>
        <m2:hasDefaultValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.196</m2:hasDefaultValue>
        <rdfs:comment>σ = 1/incubation = 1/5.1 ≈ 0.196 /jour. Source : Ferguson et al. 2020.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Param_Gamma_Ferguson_2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#RecoveryRateParameter"/>
        <rdfs:label>γ — Ferguson 2020</rdfs:label>
        <m2:hasParameterSymbol>γ</m2:hasParameterSymbol>
        <m2:hasDefaultValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.143</m2:hasDefaultValue>
        <rdfs:comment>γ = 1/infectiosité = 1/7 ≈ 0.143 /jour. Source : Ferguson et al. 2020.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Param_R0_Ferguson_2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#BasicReproductionNumber"/>
        <rdfs:label>R0 — Ferguson 2020</rdfs:label>
        <m2:hasParameterSymbol>R0</m2:hasParameterSymbol>
        <m2:hasDefaultValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">3.0</m2:hasDefaultValue>
        <rdfs:comment>R0 = 2.4–3.3. Valeur centrale 3.0. Source : Ferguson et al. 2020.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Lier les paramètres au modèle Ferguson -->
    <rdf:Description rdf:about="http://www.pacadi.org/these/piponto/module2#SEIR_COVID_Ferguson_2020">
        <m2:hasModelParameter rdf:resource="http://www.pacadi.org/these/piponto/module2#Param_Beta_Ferguson_2020"/>
        <m2:hasModelParameter rdf:resource="http://www.pacadi.org/these/piponto/module2#Param_Sigma_Ferguson_2020"/>
        <m2:hasModelParameter rdf:resource="http://www.pacadi.org/these/piponto/module2#Param_Gamma_Ferguson_2020"/>
        <m2:hasModelParameter rdf:resource="http://www.pacadi.org/these/piponto/module2#Param_R0_Ferguson_2020"/>
    </rdf:Description>

    <!-- Paramètres Cauchemez 2011 (milieu scolaire) -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Param_Beta_School_Cauchemez_2011">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#TransmissionRateParameter"/>
        <rdfs:label>β_école — Cauchemez 2011</rdfs:label>
        <m2:hasParameterSymbol>β_école</m2:hasParameterSymbol>
        <m2:hasDefaultValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.6</m2:hasDefaultValue>
        <rdfs:comment>β en milieu scolaire > β population générale (contacts rapprochés élevés).
        Source : Cauchemez et al. 2011.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Param_R0_School_Cauchemez_2011">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#BasicReproductionNumber"/>
        <rdfs:label>R0_école — Cauchemez 2011</rdfs:label>
        <m2:hasParameterSymbol>R0_école</m2:hasParameterSymbol>
        <m2:hasDefaultValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">1.3</m2:hasDefaultValue>
        <rdfs:comment>R0 en milieu scolaire pour grippe saisonnière = 1.3.
        Source : Cauchemez et al. 2011.</rdfs:comment>
    </owl:NamedIndividual>

    <rdf:Description rdf:about="http://www.pacadi.org/these/piponto/module2#SEIR_School_Cauchemez_2011">
        <m2:hasModelParameter rdf:resource="http://www.pacadi.org/these/piponto/module2#Param_Beta_School_Cauchemez_2011"/>
        <m2:hasModelParameter rdf:resource="http://www.pacadi.org/these/piponto/module2#Param_R0_School_Cauchemez_2011"/>
    </rdf:Description>

    <!-- Paramètres Roux 2020 (COVID France) -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module2#Param_R0_France_Roux_2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module2#BasicReproductionNumber"/>
        <rdfs:label>R0 France — Roux 2020</rdfs:label>
        <m2:hasParameterSymbol>R0</m2:hasParameterSymbol>
        <m2:hasDefaultValue rdf:datatype="http://www.w3.org/2001/XMLSchema#double">3.0</m2:hasDefaultValue>
        <rdfs:comment>R0 France avant confinement = 3.0. Après confinement = 0.5.
        Source : Roux et al. 2020.</rdfs:comment>
    </owl:NamedIndividual>

    <rdf:Description rdf:about="http://www.pacadi.org/these/piponto/module2#SEIR_COVID_France_Roux_2020">
        <m2:hasModelParameter rdf:resource="http://www.pacadi.org/these/piponto/module2#Param_R0_France_Roux_2020"/>
    </rdf:Description>

</rdf:RDF>
