<?xml version="1.0"?>
<!--
    MODULE 8 : Ontologie du Domaine Épidémiologique
    Ontologie : PIPOnto — http://www.pacadi.org/these/piponto/
    Auteur     : Paul Cheikh Anta DIOUF

    ╔══════════════════════════════════════════════════════════════════════════╗
    ║  M8 EST LE MODULE D'ABOUTISSEMENT DE L'ONTOLOGIE PIPOnto               ║
    ║                                                                          ║
    ║  Il ne se contente pas d'importer M2 (modèles) :                        ║
    ║  il est le pont entre le DOMAINE RÉEL et TOUTE la chaîne PIPOnto.       ║
    ║                                                                          ║
    ║  M0 → les fondements ontologiques (Endurant, Process, Quality...)       ║
    ║  M1 → les systèmes complexes (Agent, Population, Environnement...)      ║
    ║  M2 → les modèles mathématiques qui abstraient le domaine               ║
    ║  M3 → les agents simulés qui incarnent les hôtes et pathogènes          ║
    ║  M4 → les simulations qui exécutent les modèles sur ce domaine          ║
    ║  M5 → les expériences qui testent des hypothèses sur ce domaine         ║
    ║  M6 → les résultats qui quantifient l'état de ce domaine                ║
    ║  M7 → les alignements qui ancrent ce domaine dans les standards         ║
    ║  M8 → LE DOMAINE LUI-MÊME, qui donne sens à toute la chaîne            ║
    ╚══════════════════════════════════════════════════════════════════════════╝

    CHOIX DE CONCEPTION DOCUMENTÉS :

      [M8-D1] M8 importe TOUS les modules M0–M7 :
              M8 est la couche domaine qui donne sens à l'ensemble de PIPOnto.
              Sans M8, les modules techniques (M2–M6) modélisent "quelque chose".
              Avec M8, ils modélisent des MALADIES INFECTIEUSES RÉELLES dans des
              POPULATIONS RÉELLES. M8 instancie et relie tous les concepts abstraits
              définis dans les modules précédents.

      [M8-D2] Ponts M8 → M3 (Agents Simulés) :
              ImmunologicalStatus (M8) ↔ EpidemiologicalStatus (M3)
              HumanHost (M8) est modélisé par SimulatedAgent (M3)
              PublicHealthIntervention (M8) se traduit en VaccinationAction/
              QuarantineAction/ContactAction (M3) dans les ABM.

      [M8-D3] Ponts M8 → M4 (Simulation) :
              EpidemicEvent (M8) isSimulatedBy Simulation (M4)
              PopulationGroup (M8) fournit les InitialCondition (M4) : N, S0, I0...
              GeographicContext (M8) fournit le SimulationConfiguration (M4)
              PublicHealthIntervention (M8) génère un InterventionScenario (M4)
              Pathogen.hasR0Value (M8) → TransmissionRateParameter (M4/M2)

      [M8-D4] Ponts M8 → M5 (Expérimentation) :
              EpidemicEvent (M8) isSubjectOfExperiment Experiment (M5)
              L'Experiment (M5) teste des hypothèses sur un EpidemicEvent (M8)
              PublicHealthIntervention (M8) est le facteur testé dans
              ScenarioComparisonExperiment (M5)

      [M8-D5] Ponts M8 → M6 (Résultats) :
              EpidemiologicalMetric (M6) quantifiesAspectOf InfectiousDisease (M8)
              EpidemicPeakMetric (M6) mesure le pic de InfectedStatus (M8)
              PolicyRecommendation (M6) recommande PublicHealthIntervention (M8)
              ComparisonResult (M6) compare des InterventionScenario liés à
              des PublicHealthIntervention (M8)

      [M8-D6] Instanciation des alignements M7 dans M8 :
              Les alignements IDO/OGMS déclarés en M7 (anticipatoires) sont ici
              pleinement développés avec leurs sous-classes et propriétés.
              InfectiousDisease ≡ IDO_0000528, Host ≡ IDO_0000531.

      [M8-D7] Propriétés de sélection automatique de modèle :
              hasR0Value, hasIncubationPeriodDays, hasImmunityDurationDays
              sont les critères SPARQL pour sélectionner le modèle M2 optimal.
              bestModeledBy est la propriété synthétique qui encode le résultat
              de cette sélection pour interrogation directe par la plateforme NLP.
-->
<rdf:RDF xmlns="http://www.pacadi.org/these/piponto/module8#"
     xml:base="http://www.pacadi.org/these/piponto/module8"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:m8="http://www.pacadi.org/these/piponto/module8#"
     xmlns:m2="http://www.pacadi.org/these/piponto/module2#">

    <owl:Ontology rdf:about="http://www.pacadi.org/these/piponto/module8">
        <owl:versionIRI rdf:resource="http://www.pacadi.org/these/piponto/module8"/>
        <owl:imports rdf:resource="http://www.pacadi.org/these/piponto/module0"/>
        <owl:imports rdf:resource="http://www.pacadi.org/these/piponto/module1"/>
        <owl:imports rdf:resource="http://www.pacadi.org/these/piponto/module2"/>
        <owl:imports rdf:resource="http://www.pacadi.org/these/piponto/module3"/>
        <owl:imports rdf:resource="http://www.pacadi.org/these/piponto/module4"/>
        <owl:imports rdf:resource="http://www.pacadi.org/these/piponto/module5"/>
        <owl:imports rdf:resource="http://www.pacadi.org/these/piponto/module6"/>
        <owl:imports rdf:resource="http://www.pacadi.org/these/piponto/module7"/>
        <rdfs:label>PIPOnto - Module 8 : Domaine Épidémiologique (Module d'aboutissement)</rdfs:label>
        <rdfs:comment>Module d'aboutissement de PIPOnto. Ancre le domaine réel
        (maladies infectieuses, pathogènes, hôtes, populations, interventions) dans toute
        la chaîne M0-M7. Donne sens à l'ensemble de la plateforme.</rdfs:comment>
    </owl:Ontology>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    // SECTION 1 : PROPRIÉTÉS OBJET
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <!-- ─── Liens M8 → M2 (Modèles) [M8-D7] ─── -->

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#bestModeledBy">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module2#Model"/>
        <rdfs:comment>[M8-D7, pont M8→M2] Propriété clé pour la sélection automatique de modèle.
        Interrogée par SPARQL : "COVID-19" → SEIRModel. Calculée à partir de
        hasIncubationPeriodDays et hasImmunityDurationDays (M8) et des ModelSelectionCriteria (M2).</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasModelSelectionCriteria">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#hasAttribute"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module2#ModelSelectionCriteria"/>
        <rdfs:comment>[pont M8→M2] Critères de sélection du modèle dérivés des caractéristiques
        épidémiologiques de la maladie. Ex: incubation > 0 → SEIRModelCriteria.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#calibratesParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module2#ModelParameter"/>
        <rdfs:comment>[pont M8→M2] Les propriétés biologiques du pathogène calibrent les
        paramètres du modèle (M2) :
        hasR0Value          → β = R0 x gamma
        hasIncubationPeriod → sigma = 1 / incubation
        hasInfectiousPeriod → gamma = 1 / infectiosite
        hasImmunityDuration → omega = 1 / immunityDuration
        Entrée pour ModelCalibrationExperiment (M5).</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#reducesParameter">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module2#ModelParameter"/>
        <rdfs:comment>[pont M8→M2] Une intervention réduit un paramètre du modèle.
        SocialDistancing reducesParameter beta ; Quarantine reducesParameter beta ;
        VaccinationCampaign reducesParameter S0 (conditions initiales M4).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- ─── Liens M8 → M3 (Agents Simulés) [M8-D2] ─── -->

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isModeledByAgent">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module2#abstractsFrom"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#Host"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module3#SimulatedAgent"/>
        <rdfs:comment>[M8-D2, pont M8→M3] Un hôte réel (M8) est modélisé par un SimulatedAgent (M3).
        HumanHost isModeledByAgent → EpidemiologicalAgent avec EpidemiologicalStatus
        correspondant à ImmunologicalStatus (M8).</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#correspondsToStatus">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#ImmunologicalStatus"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module3#EpidemiologicalStatus"/>
        <rdfs:comment>[M8-D2, pont M8→M3] Le statut immunologique réel (M8) correspond au
        statut de l'agent simulé (M3). Pont essentiel pour valider le modèle ABM sur
        données réelles. SusceptibleStatus ↔ SusceptibleAgent (M3).</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isImplementedAsAction">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#causes"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module3#AgentAction"/>
        <rdfs:comment>[M8-D2, pont M8→M3] Une intervention (M8) est implémentée comme
        action d'agent (M3) dans les ABM :
        VaccinationCampaign → VaccinationAction (M3)
        Quarantine          → SimulatedNorm sur InfectedAgent (M3)
        SocialDistancing    → réduction hasPerceptionRadius dans MoveAction (M3)
        ContactTracing      → inspection réseau de contacts de l'agent (M3)</rdfs:comment>
    </owl:ObjectProperty>

    <!-- ─── Liens M8 → M4 (Simulation) [M8-D3] ─── -->

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isSimulatedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemicEvent"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module4#Simulation"/>
        <rdfs:comment>[M8-D3, pont M8→M4] Lien central entre le REEL et le SIMULE.
        Un événement épidémique réel (M8) est reproduit par une Simulation (M4).
        Une même EpidemicEvent peut être isSimulatedBy plusieurs Simulations (comparaison M5).</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#providesInitialConditions">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#causes"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module4#InitialCondition"/>
        <rdfs:comment>[M8-D3, pont M8→M4] PopulationGroup (M8) fournit les conditions initiales M4 :
        hasPopulationSize → N ; S0 = N x (1 - tauxImmunite) ; I0 = casIndex.
        Extrait par NLP : "Montréal" → N=2049000.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#configuresScenario">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#causes"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module4#InterventionScenario"/>
        <rdfs:comment>[M8-D3, pont M8→M4] Une intervention (M8) configure automatiquement
        un InterventionScenario (M4) avec les paramètres modifiés.
        VaccinationCampaign(coverage=0.7, efficacy=0.9) → InterventionScenario(S0 reduit de 63%)
        SocialDistancing(efficacy=0.4) → InterventionScenario(beta reduit de 40%)</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#definesGeographicScope">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module4#SimulationConfiguration"/>
        <rdfs:comment>[M8-D3, pont M8→M4] GeographicContext (M8) definit la portée spatiale
        de SimulationConfiguration (M4) : charge SHP/GeoJSON pour GISTopology (M3),
        définit ModelScope (M2) Local/Regional/Global, fournit données climatiques.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- ─── Liens M8 → M5 (Expérimentation) [M8-D4] ─── -->

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isSubjectOfExperiment">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemicEvent"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module5#Experiment"/>
        <rdfs:comment>[M8-D4, pont M8→M5] Un événement épidémique (M8) est l'objet d'étude
        d'un Experiment (M5) : validation de modèle, comparaison de scénarios,
        analyse de sensibilité. Ex: COVIDMontreal isSubjectOfExperiment ValidationExpCOVID.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isTestedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module5#ScenarioComparisonExperiment"/>
        <rdfs:comment>[M8-D4, pont M8→M5] Une intervention (M8) est évaluée par un
        ScenarioComparisonExperiment (M5) comparant le scénario de base au scénario
        interventionnel. Résultat → PolicyRecommendation (M6).</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#requiresCalibration">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module5#ModelCalibrationExperiment"/>
        <rdfs:comment>[pont M8→M5] Une maladie requiert calibration (M5) quand ses paramètres
        ne sont pas connus pour un contexte géographique. Beta COVID-19 à Thiès != beta à Montréal.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- ─── Liens M8 → M6 (Résultats) [M8-D5] ─── -->

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isQuantifiedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module6#EpidemiologicalMetric"/>
        <rdfs:comment>[M8-D5, pont M8→M6] Une maladie infectieuse (M8) est quantifiée par
        les métriques épidémiologiques (M6) : EpidemicPeakMetric, AttackRateMetric,
        EffectiveReproductionNumberMetric... Ces métriques donnent sens aux résultats simulés.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#informs">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#causes"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module6#ComparisonResult"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:comment>[M8-D5, pont M6→M8] Boucle de rétroaction de la plateforme :
        Simulation (M4) → Résultats (M6) → ComparisonResult informe → Intervention (M8).
        Ex: ComparisonResult(vaccination vs lockdown) informs → VaccinationCampaign préférée.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#generatesRecommendation">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#causes"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module6#SimulationReport"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:comment>[pont M6→M8] Finalité applicative de PIPOnto :
        SimulationReport (M6) → recommande VaccinationCampaign(coverage >= 0.67) concrète (M8).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- ─── Propriétés internes M8 ─── -->

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isCausedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#causes"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#affects">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#Host"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasTransmissionRoute">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#hasAttribute"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#TransmissionRoute"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasNaturalHistory">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#hasAttribute"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#NaturalHistory"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#occursIn">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#locatedIn"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemicEvent"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#involves">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemicEvent"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isSubjectOf">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemicEvent"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasReservoir">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#hasAttribute"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#Host"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasVector">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#hasAttribute"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#VectorBorneDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#BiologicalVector"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasImmunologicalStatus">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#hasState"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#Host"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#ImmunologicalStatus"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#targetsPopulation">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#influences"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasEfficacy">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#hasAttribute"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#InterventionEfficacy"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isLocatedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.pacadi.org/these/piponto/module0#locatedIn"/>
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
    </owl:ObjectProperty>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    // SECTION 2 : PROPRIÉTÉS DE DONNÉES
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasR0Value">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>[M8-D7] R0 : critère SPARQL primaire pour sélection de modèle.
        R0 > 1 → épidémie possible. Alimente calibratesParameter beta = R0 x gamma (M2/M4).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasIncubationPeriodDays">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>[M8-D7] Durée incubation (jours). > 0 → compartiment E requis → SEIR/SEIRS (M2).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasInfectiousPeriodDays">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>Durée d'infectiosite (jours). Alimente gamma = 1/hasInfectiousPeriodDays (M2).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasImmunityDurationDays">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>[M8-D7] Durée immunité (jours). Finie → SIRS/SEIRS (M2). INF → SIR/SEIR.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasCaseFatalityRate">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>CFR. > 0.05 → compartiment D requis dans le modèle (M2). Alimente EpidemicPeakMetric (M6).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#isZoonotic">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Vrai si zoonotique → modéliser le réservoir animal dans M2/M3.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasPopulationSize">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>[pont M8→M4] N de la population → InitialCondition N (M4). Extrait par NLP.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasPopulationDensity">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>Densité (hab/km2) → influence beta effectif dans les ABM (M3).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasCoverageRate">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>[pont M8→M4] Taux de couverture → reduit S0 dans InitialCondition (M4).
        VaccinationCampaign(coverage=0.7, efficacy=0.9) → S0_eff = S0 x (1 - 0.63).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasEfficacyValue">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InterventionEfficacy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasISOCountryCode">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Code ISO 3166-1 → liaison bases démographiques OMS/ONU/MSAS/INSPQ.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasGeoCoordinates">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Coordonnées (lat, lon) → charge GISTopology (M3) pour simulations spatiales.</rdfs:comment>
    </owl:DatatypeProperty>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    // SECTION 3 : CLASSES
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <!-- ═══ MALADIES INFECTIEUSES (M0 + IDO via M7) ═══ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#InfectiousDisease">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module0#Perdurant"/>
        <owl:equivalentClass rdf:resource="http://purl.obolibrary.org/obo/IDO_0000528"/>
        <rdfs:comment>[M8-D1 à D7] Classe centrale de M8. Ancrée dans Perdurant (M0).
        Alignée IDO (M7 instancié). Connectée à M2 (bestModeledBy), M4 (isSimulatedBy via EpidemicEvent),
        M5 (requiresCalibration, isSubjectOfExperiment), M6 (isQuantifiedBy).
        Pilote toute la chaine de sélection automatique de modele de la plateforme.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#SIRDisease">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:comment>Pas d'incubation + immunité permanente → SIRModel (M2). Ex: Rougeole.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#SEIRDisease">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:comment>Incubation + immunité permanente → SEIRModel (M2). Ex: COVID-19, SARS, Ebola.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#SIRSDisease">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:comment>Pas d'incubation + immunité temporaire → SIRSModel (M2).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#SEIRSDisease">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:comment>Incubation + immunité temporaire → SEIRSModel (M2). Ex: COVID-19 avec réinfection, Paludisme, Dengue.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#VectorBorneDisease">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:comment>Transmission vectorielle → modèle deux populations hôtes+vecteurs M2/M3. Ex: Paludisme, Dengue.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#AirborneDisease">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:comment>Transmission aérienne. beta influencé par densité, ventilation, distance → GISTopology (M3).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#ZoonoticDisease">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:comment>Maladie zoonotique → réservoir animal modélisé dans M2/M3.</rdfs:comment>
    </owl:Class>

    <!-- ═══ PATHOGÈNES (M0) ═══ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Pathogen">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module0#BiologicalObject"/>
        <rdfs:comment>[M8-D7] Ses propriétés biologiques (R0, incubation, infectiosite, immunité)
        sont les paramètres d'entrée du pipeline de sélection automatique (M2) et de calibration (M5).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Virus">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Bacterium">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Parasite">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#Pathogen"/>
    </owl:Class>

    <!-- Instances pathogènes -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#SARS_CoV_2">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#Virus"/>
        <rdfs:label>SARS-CoV-2</rdfs:label>
        <rdfs:comment>R0 ≈ 2.5–3.5 ; incubation ≈ 5.1j ; infectiosite ≈ 5-10j.
        bestModeledBy → SEIRModel. calibratesParameter : beta ≈ 0.3/j, sigma ≈ 1/5.1, gamma ≈ 1/7.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_2697049"/>
            <m8:hasR0Value rdf:datatype="http://www.w3.org/2001/XMLSchema#double">3.0</m8:hasR0Value>
        <m8:hasIncubationPeriodDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">5.1</m8:hasIncubationPeriodDays>
        <m8:hasInfectiousPeriodDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">7.0</m8:hasInfectiousPeriodDays>
        <m8:hasImmunityDurationDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">120.0</m8:hasImmunityDurationDays>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#InfluenzaVirus">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#Virus"/>
        <rdfs:label>Influenza Virus A/B</rdfs:label>
        <rdfs:comment>R0 ≈ 1.2–1.4 (saisonnier) ; immunité saisonnière. bestModeledBy → SIRSModel ou SEIRSModel.</rdfs:comment>
            <m8:hasR0Value rdf:datatype="http://www.w3.org/2001/XMLSchema#double">1.3</m8:hasR0Value>
        <m8:hasIncubationPeriodDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">2.0</m8:hasIncubationPeriodDays>
        <m8:hasInfectiousPeriodDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">4.0</m8:hasInfectiousPeriodDays>
        <m8:hasImmunityDurationDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">180.0</m8:hasImmunityDurationDays>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#PlasmodiumFalciparum">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#Parasite"/>
        <rdfs:label>Plasmodium falciparum</rdfs:label>
        <rdfs:comment>Pathogène du Paludisme — endémie Sénégal/Afrique subsaharienne. Contexte Thiès.
        VectorBorneDisease + SEIRSDisease → modèle Ross-Macdonald (M2) + deux populations (M3).</rdfs:comment>
            <m8:hasR0Value rdf:datatype="http://www.w3.org/2001/XMLSchema#double">100.0</m8:hasR0Value>
        <m8:hasIncubationPeriodDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">12.0</m8:hasIncubationPeriodDays>
        <m8:hasInfectiousPeriodDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">30.0</m8:hasInfectiousPeriodDays>
        <m8:hasImmunityDurationDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">180.0</m8:hasImmunityDurationDays>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#EbolaVirus">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#Virus"/>
        <rdfs:label>Ebola Virus</rdfs:label>
        <rdfs:comment>R0 ≈ 1.5–2.5 ; incubation ≈ 8-21j ; CFR ≈ 50-90%.
        bestModeledBy → SEIRModel avec compartiment D (mortalité).</rdfs:comment>
            <m8:hasR0Value rdf:datatype="http://www.w3.org/2001/XMLSchema#double">2.0</m8:hasR0Value>
        <m8:hasIncubationPeriodDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">12.0</m8:hasIncubationPeriodDays>
        <m8:hasInfectiousPeriodDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">9.0</m8:hasInfectiousPeriodDays>
        <m8:hasImmunityDurationDays rdf:datatype="http://www.w3.org/2001/XMLSchema#double">99999.0</m8:hasImmunityDurationDays>
    </owl:NamedIndividual>

    <!-- ═══ HÔTES ET STATUTS IMMUNOLOGIQUES (M0+M1, IDO via M7, M3) ═══ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Host">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module1#BiologicalAgent"/>
        <owl:equivalentClass rdf:resource="http://purl.obolibrary.org/obo/IDO_0000531"/>
        <rdfs:comment>[M8-D2, M8-D6] Aligné IDO (M7 instancié). Lié à SimulatedAgent (M3)
        via isModeledByAgent. ImmunologicalStatus correspond à EpidemiologicalStatus (M3).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#HumanHost">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#Host"/>
        <rdfs:comment>→ EpidemiologicalAgent (M3). Propriétés démographiques influencent beta et gamma.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#AnimalHost">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#Host"/>
        <rdfs:comment>Réservoir ou hôte intermédiaire → population secondaire M2/M3.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#BiologicalVector">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#Host"/>
        <rdfs:comment>Vecteur biologique → population active dans modèles vectoriels (M2/M3).</rdfs:comment>
    </owl:Class>

    <!-- Statuts immunologiques — correspondance avec compartiments M2 ET statuts M3 -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#ImmunologicalStatus">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module0#State"/>
        <skos:closeMatch rdf:resource="http://purl.obolibrary.org/obo/IDO_0000622"/>
        <rdfs:comment>[M8-D2, M8-D6] Etat immunologique d'un hôte. Triple correspondance :
        compartiment modèle (M2) + statut agent simulé (M3) + condition initiale (M4).
        correspondsToStatus relie chaque instance à son équivalent simulé (M3).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#SusceptibleStatus">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ImmunologicalStatus"/>
        <rdfs:comment>→ Compartiment S (M2) ; → SusceptibleAgent (M3) ; → InitialCondition S0 (M4).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#ExposedStatus">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ImmunologicalStatus"/>
        <rdfs:comment>→ Compartiment E (M2, SEIR) ; → ExposedAgent (M3) ; → E0 (M4).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#InfectedStatus">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ImmunologicalStatus"/>
        <rdfs:comment>→ Compartiment I (M2) ; → InfectiousAgent (M3) → déclenche TransmissionAction (M3) ;
        → I0 (M4) ; → EpidemicPeakMetric (M6).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#RecoveredStatus">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ImmunologicalStatus"/>
        <rdfs:comment>→ Compartiment R (M2) ; → RecoveredAgent (M3) ; → FinalEpidemicSizeMetric (M6).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#VaccinatedStatus">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ImmunologicalStatus"/>
        <rdfs:comment>→ Compartiment V ; → S→V via VaccinationAction (M3) dans ABM ;
        → S0 réduit (M4) ; → HerdImmunityThresholdMetric (M6).</rdfs:comment>
    </owl:Class>

    <!-- ═══ TRANSMISSION ═══ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#TransmissionRoute">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module0#Attribute"/>
        <rdfs:comment>Voie de transmission → formalisme modèle (M2) et paramètres contact (M3).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#AerialTransmission">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#TransmissionRoute"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#DirectContactTransmission">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#TransmissionRoute"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#VectorialTransmission">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#TransmissionRoute"/>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#FecalOralTransmission">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#TransmissionRoute"/>
    </owl:Class>

    <!-- ═══ ÉVÉNEMENTS ÉPIDÉMIQUES (pont M8→M4, M5) ═══ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#EpidemicEvent">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module0#InteractionEvent"/>
        <rdfs:comment>[M8-D3, M8-D4] Entité centrale — l'événement réel que PIPOnto modélise.
        isSimulatedBy → Simulation (M4) : raison d'être de la simulation.
        isSubjectOfExperiment → Experiment (M5) : objet de la recherche.
        occursIn → GeographicContext ; involves → PopulationGroup.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Epidemic">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemicEvent"/>
        <rdfs:comment>R(t) > 1. → LocalScope (M2).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Pandemic">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemicEvent"/>
        <rdfs:comment>Diffusion mondiale → modèles multi-régions avec migration. → GlobalScope (M2).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Endemic">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemicEvent"/>
        <rdfs:comment>R(t) ≈ 1 en équilibre → modèles avec démographie (naissances/décès) + longue durée (M4).</rdfs:comment>
    </owl:Class>

    <!-- ═══ POPULATIONS ET GÉOGRAPHIE (ponts M8→M4) ═══ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#PopulationGroup">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module1#AgentPopulation"/>
        <rdfs:comment>[M8-D3] Fournit InitialCondition (M4) : N, S0, I0...
        Extrait par NLP de la requête utilisateur.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#AgeGroup">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:comment>Sous-groupe par âge → paramètres différentiels beta, gamma dans M2/M3.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#GeographicContext">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module1#PhysicalEnvironment"/>
        <rdfs:comment>[M8-D3] definesGeographicScope → SimulationConfiguration (M4).
        Charge GISTopology (M3). Extrait par NLP : "à Montréal", "au Sénégal".</rdfs:comment>
    </owl:Class>

    <!-- Instances géographiques — interrogeables par SPARQL -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Montreal">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:label>Montréal, Québec, Canada</rdfs:label>
        <rdfs:comment>Cas d'usage principal de la thèse. ISO: CA-QC.
        Population ≈ 2 049 000 ; densité ≈ 4 517 hab/km2.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Senegal">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:label>Sénégal</rdfs:label>
        <rdfs:comment>Contexte institutionnel (UCAD). ISO: SN. Population ≈ 17 700 000.
        Endémie Paludisme + cas COVID-19.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Thies">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:label>Thiès, Sénégal</rdfs:label>
        <rdfs:comment>Région Thiès — simulations locales Sénégal. Population ≈ 1 100 000.
        Paludisme saison des pluies, contexte urbain/rural mixte.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ═══ INTERVENTIONS (ponts M8→M2/M3/M4/M5/M6) ═══ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module0#Process"/>
        <rdfs:comment>[M8-D2 à M8-D5] Classe multi-connectée — traversée par toute la chaine :
        M2 : reducesParameter (beta, gamma...)
        M3 : isImplementedAsAction (VaccinationAction, SimulatedNorm...)
        M4 : configuresScenario (InterventionScenario)
        M5 : isTestedBy (ScenarioComparisonExperiment)
        M6 : informs / generatesRecommendation (ComparisonResult → PolicyRecommendation)
        Point d'entrée NLP : "avec vaccination", "sous confinement", "avec distanciation".</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#VaccinationCampaign">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:comment>→ VaccinationAction (M3) ; → S0 réduit (M4) ; → HerdImmunityThresholdMetric (M6).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Quarantine">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:comment>→ SimulatedNorm (M3) sur InfectedAgent ; → beta réduit (M4).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#SocialDistancing">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:comment>→ réduction hasPerceptionRadius dans MoveAction (M3) ; → beta réduit (M4).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#MaskWearing">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:comment>→ beta réduit (efficacite x compliance) dans maladies aériennes (M4).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#Lockdown">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:comment>→ SimulatedNorm (M3) contraignant MoveAction + beta réduit fortement (M4).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#ContactTracing">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PublicHealthIntervention"/>
        <rdfs:comment>→ inspection réseau de contacts SimulatedAgent (M3) — naturellement modélisé ABM.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#InterventionEfficacy">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module0#Attribute"/>
    </owl:Class>

    <!-- ═══ HISTOIRE NATURELLE ═══ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#NaturalHistory">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module0#InformationObject"/>
        <rdfs:comment>Progression naturelle d'une maladie → structure les compartiments (M2)
        et le BaselineScenario (M4).</rdfs:comment>
    </owl:Class>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    // SECTION 4 : INDIVIDU CANONIQUE — PIPELINE NLP COMPLET
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#COVIDMontreal2020">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#Epidemic"/>
        <rdfs:label>COVID-19 à Montréal (2020)</rdfs:label>
        <rdfs:comment>EpidemicEvent canonique — illustre le pipeline complet de PIPOnto.
        Requête NLP : "simule COVID-19 à Montréal"

        [M8]  EpidemicEvent : COVIDMontreal2020
              isCausedBy       → SARS-CoV-2 (Pathogen M8)
              occursIn         → Montreal (GeographicContext M8)
              involves         → PopulationGroup(N=2049000) (M8)

        [M8→M2] SARS-CoV-2 bestModeledBy → SEIRModel (M2)
              calibratesParameter → beta, sigma, gamma (M2)

        [M8→M3] HumanHost isModeledByAgent → EpidemiologicalAgent (M3)
              ImmunologicalStatus correspondsToStatus → EpidemiologicalStatus (M3)
              VaccinationCampaign isImplementedAsAction → VaccinationAction (M3)

        [M8→M4] COVIDMontreal2020 isSimulatedBy → GAMASimulation(SEIRModel, N=2049000)
              PopulationGroup providesInitialConditions → InitialCondition(S0=2048990, I0=10) (M4)
              GeographicContext definesGeographicScope → SimulationConfig(GISTopology=Montreal.shp) (M4)
              VaccinationCampaign configuresScenario → InterventionScenario (M4)

        [M8→M5] COVIDMontreal2020 isSubjectOfExperiment → ModelValidationExperiment (M5)
              VaccinationCampaign isTestedBy → ScenarioComparisonExperiment (M5)
              SARS-CoV-2 requiresCalibration → ModelCalibrationExperiment(contexte Montreal) (M5)

        [M8→M6] InfectiousDisease isQuantifiedBy → EpidemicPeakMetric, AttackRateMetric (M6)
              ComparisonResult(vaccination vs lockdown) informs → VaccinationCampaign (M8)
              SimulationReport generatesRecommendation → VaccinationCampaign(coverage=0.67) (M8)

        [M7]  InfectiousDisease = IDO_0000528 ; Experiment = prov:Activity ; Result = prov:Entity
              SimulationReport → PROV-O compatible pour archivage et reproductibilité.</rdfs:comment>
    </owl:NamedIndividual>


    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    // SECTION 5 : ABOX — INSTANCES (données)
    // Individus concrets : maladies, pathogènes, populations, événements, interventions
    ///////////////////////////////////////////////////////////////////////////////////////
    -->




    

    <!-- COVID-19 -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#COVID19">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#SEIRDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#AirborneDisease"/>
        <rdfs:label xml:lang="fr">COVID-19</rdfs:label>
        <m8:isCausedBy rdf:resource="http://www.pacadi.org/these/piponto/module8#SARS_CoV_2"/>
        <m8:bestModeledBy rdf:resource="http://www.pacadi.org/these/piponto/module2#SEIRModel"/>
        <m8:hasTransmissionRoute rdf:resource="http://www.pacadi.org/these/piponto/module8#AerialTransmission"/>
        <m8:hasCaseFatalityRate rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.02</m8:hasCaseFatalityRate>
        <m8:isZoonotic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</m8:isZoonotic>
        <rdfs:comment>Maladie à coronavirus SARS-CoV-2. Incubation ~5j → compartiment E requis.
        Immunité temporaire selon variant → SEIRModel (souche originale) ou SEIRSModel (réinfections).
        bestModeledBy → SEIRModel par défaut.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- COVID-19 avec réinfection (variant Omicron) -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#COVID19_Reinfection">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#SEIRSDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#AirborneDisease"/>
        <rdfs:label xml:lang="fr">COVID-19 avec réinfection (Omicron)</rdfs:label>
        <m8:isCausedBy rdf:resource="http://www.pacadi.org/these/piponto/module8#SARS_CoV_2"/>
        <m8:bestModeledBy rdf:resource="http://www.pacadi.org/these/piponto/module2#SEIRSModel"/>
        <m8:hasCaseFatalityRate rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.005</m8:hasCaseFatalityRate>
        <m8:isZoonotic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</m8:isZoonotic>
    </owl:NamedIndividual>

    <!-- Grippe saisonnière -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#SeasonalInfluenza">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#SIRSDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#AirborneDisease"/>
        <rdfs:label xml:lang="fr">Grippe saisonnière</rdfs:label>
        <m8:isCausedBy rdf:resource="http://www.pacadi.org/these/piponto/module8#InfluenzaVirus"/>
        <m8:bestModeledBy rdf:resource="http://www.pacadi.org/these/piponto/module2#SIRSModel"/>
        <m8:hasTransmissionRoute rdf:resource="http://www.pacadi.org/these/piponto/module8#AerialTransmission"/>
        <m8:hasCaseFatalityRate rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.001</m8:hasCaseFatalityRate>
        <m8:isZoonotic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</m8:isZoonotic>
        <rdfs:comment>Immunité saisonnière (~6 mois) → compartiment R rechargeable → SIRS.
        Incubation courte (1-4j) souvent intégrée dans beta → pas de compartiment E explicite.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Paludisme -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Malaria">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#SEIRSDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#VectorBorneDisease"/>
        <rdfs:label xml:lang="fr">Paludisme</rdfs:label>
        <m8:isCausedBy rdf:resource="http://www.pacadi.org/these/piponto/module8#PlasmodiumFalciparum"/>
        <m8:bestModeledBy rdf:resource="http://www.pacadi.org/these/piponto/module2#SEIRSModel"/>
        <m8:hasTransmissionRoute rdf:resource="http://www.pacadi.org/these/piponto/module8#VectorialTransmission"/>
        <m8:hasCaseFatalityRate rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.003</m8:hasCaseFatalityRate>
        <m8:isZoonotic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</m8:isZoonotic>
        <rdfs:comment>Endémie majeure Sénégal/Afrique subsaharienne. Contexte Thiès.
        Vecteur Anopheles → deux populations (hôtes + moustiques).
        Immunité partielle et temporaire → SEIRS. Modèle Ross-Macdonald ou SEIRS deux populations.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rougeole -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Measles">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#SIRDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#AirborneDisease"/>
        <rdfs:label xml:lang="fr">Rougeole</rdfs:label>
        <m8:bestModeledBy rdf:resource="http://www.pacadi.org/these/piponto/module2#SIRModel"/>
        <m8:hasTransmissionRoute rdf:resource="http://www.pacadi.org/these/piponto/module8#AerialTransmission"/>
        <m8:hasCaseFatalityRate rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.001</m8:hasCaseFatalityRate>
        <m8:isZoonotic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</m8:isZoonotic>
        <rdfs:comment>Immunité à vie après infection ou vaccination → compartiment R permanent → SIR.
        R0 = 12-18 (le plus élevé des maladies communes).</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Ebola -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#EbolaDiseaseInstance">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#SEIRDisease"/>
