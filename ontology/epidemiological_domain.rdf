    <!-- ═══════════════════════════════════════════════════
         [M8-EXT-1] SOUS-CLASSES DE POPULATION SPÉCIFIQUES
         subClassOf PopulationGroup existant
         ═══════════════════════════════════════════════════ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#SchoolChildren">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:label xml:lang="fr">Enfants scolarisés</rdfs:label>
        <rdfs:label xml:lang="en">School Children</rdfs:label>
        <rdfs:comment>[M8-EXT-1] Population scolaire (6-18 ans). Taux de contact élevé en classe.
        Mots-clés NLP : écoliers, élèves, enfants, collégiens, lycéens, école.
        Lié à m2:SchoolPopulation via hasM2PopulationContext.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#ElderlyPopulation">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:label xml:lang="fr">Personnes âgées (65+)</rdfs:label>
        <rdfs:label xml:lang="en">Elderly Population</rdfs:label>
        <rdfs:comment>[M8-EXT-1] Population de 65 ans et plus. Risque élevé de formes graves.
        Mots-clés NLP : personnes âgées, seniors, EHPAD, retraités.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#HealthcareWorkers">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:label xml:lang="fr">Travailleurs de santé</rdfs:label>
        <rdfs:label xml:lang="en">Healthcare Workers</rdfs:label>
        <rdfs:comment>[M8-EXT-1] Personnel soignant exposé professionnellement.
        Mots-clés NLP : soignants, médecins, infirmiers, hôpital, personnel médical.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#UrbanPopulationGroup">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:label xml:lang="fr">Population urbaine dense</rdfs:label>
        <rdfs:label xml:lang="en">Dense Urban Population</rdfs:label>
        <rdfs:comment>[M8-EXT-1] Population en milieu urbain dense. Forte densité = transmission élevée.
        Mots-clés NLP : ville, urbain, métropole, centre-ville.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#RuralPopulationGroup">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:label xml:lang="fr">Population rurale</rdfs:label>
        <rdfs:label xml:lang="en">Rural Population</rdfs:label>
        <rdfs:comment>[M8-EXT-1] Population en milieu rural. Accès aux soins limité.
        Mots-clés NLP : rural, campagne, village, zone rurale.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#VulnerablePopulation">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:label xml:lang="fr">Population vulnérable</rdfs:label>
        <rdfs:label xml:lang="en">Vulnerable Population</rdfs:label>
        <rdfs:comment>[M8-EXT-1] Personnes immunodéprimées, comorbidités, malnutrition.
        Mots-clés NLP : vulnérables, immunodéprimés, comorbidités, diabétiques.</rdfs:comment>
    </owl:Class>


    <!-- ═══════════════════════════════════════════════════
         [M8-EXT-2] CLASSE ExternalDataSource
         Pour INSEE, ANSD, OMS, SPF, GitHub, POLYMOD...
         ═══════════════════════════════════════════════════ -->

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#ExternalDataSource">
        <rdfs:label xml:lang="fr">Source de données externe</rdfs:label>
        <rdfs:label xml:lang="en">External Data Source</rdfs:label>
        <rdfs:comment>[M8-EXT-2] Source externe fournissant des données pour calibrer ou contextualiser
        une simulation. Ex: INSEE pour démographie Paris, ANSD pour Sénégal, OMS pour données globales.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#DemographicDataSource">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ExternalDataSource"/>
        <rdfs:label xml:lang="fr">Source de données démographiques</rdfs:label>
        <rdfs:comment>Fournit : taille population, pyramide des âges, densité, proportion scolaire.
        Ex: INSEE (France), ANSD (Sénégal), Statistics Canada.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#EpidemiologicalDataSource">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ExternalDataSource"/>
        <rdfs:label xml:lang="fr">Source de données épidémiologiques</rdfs:label>
        <rdfs:comment>Fournit : cas confirmés, hospitalisations, décès, taux vaccination.
        Ex: Santé Publique France, PNLP Sénégal, ECDC, OMS.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#ContactMatrixDataSource">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ExternalDataSource"/>
        <rdfs:label xml:lang="fr">Source de matrice de contacts</rdfs:label>
        <rdfs:comment>Fournit : matrices de contacts par tranche d'âge et lieu (école, famille, travail).
        Ex: POLYMOD (Mossong 2008), Prem et al. 2017 (matrices synthétiques mondiales).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.pacadi.org/these/piponto/module8#MobilityDataSource">
        <rdfs:subClassOf rdf:resource="http://www.pacadi.org/these/piponto/module8#ExternalDataSource"/>
        <rdfs:label xml:lang="fr">Source de données de mobilité</rdfs:label>
        <rdfs:comment>Fournit : données de déplacements, transports en commun, flux domicile-travail.
        Ex: Google Mobility Reports, Apple Mobility, données RATP.</rdfs:comment>
    </owl:Class>


    <!-- ═══════════════════════════════════════════════════
         [M8-EXT-3] NOUVELLES PROPRIÉTÉS
         ═══════════════════════════════════════════════════ -->

    <!-- Pont M8 PopulationGroup → M2 PopulationContext -->
    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasM2PopulationContext">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module2#PopulationContext"/>
        <rdfs:label xml:lang="fr">correspond au contexte populationnel M2</rdfs:label>
        <rdfs:comment>Pont M8→M2. Lie un groupe de population (M8) à son contexte M2.
        Permet aux requêtes SPARQL de traverser les deux modules.
        Ex: m8:SchoolChildren_Paris → m2:Pop_School</rdfs:comment>
    </owl:ObjectProperty>

    <!-- Lien maladie/événement → groupe de population ciblé -->
    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#affectsPopulationGroup">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#InfectiousDisease"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:label xml:lang="fr">affecte le groupe de population</rdfs:label>
        <rdfs:comment>Lie une maladie ou un événement épidémique à la population cible de la simulation.
        Clé de sélection NLP : 'chez les écoliers' → SchoolChildren → m2:SEIR_School_Cauchemez.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- Lien contexte géographique/population → source de données externe -->
    <owl:ObjectProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasDataSource">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:range rdf:resource="http://www.pacadi.org/these/piponto/module8#ExternalDataSource"/>
        <rdfs:label xml:lang="fr">a pour source de données</rdfs:label>
        <rdfs:comment>Lie un contexte géographique à sa source de données officielle.
        Ex: m8:Paris → m8:INSEE_France</rdfs:comment>
    </owl:ObjectProperty>

    <!-- Proportion scolaire dans une population -->
    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasSchoolAgeFraction">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label xml:lang="fr">fraction d'âge scolaire</rdfs:label>
        <rdfs:comment>Proportion de la population en âge scolaire (6-18 ans).
        Ex: Paris = 0.13 (13% des 2.16M habitants). Source INSEE.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- Proportion de personnes âgées -->
    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasElderlyFraction">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#PopulationGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label xml:lang="fr">fraction de personnes âgées (65+)</rdfs:label>
        <rdfs:comment>Proportion de la population de 65 ans et plus.
        Ex: France = 0.21 (21%). Source INSEE 2023.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- URL de la source de données -->
    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasSourceURL">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#ExternalDataSource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="fr">URL de la source</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Format des données disponibles -->
    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasDataFormat">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#ExternalDataSource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="fr">format des données</rdfs:label>
        <rdfs:comment>Ex: CSV, JSON, API REST, RDF.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- Couverture géographique de la source -->
    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasCoverageArea">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#ExternalDataSource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="fr">couverture géographique</rdfs:label>
        <rdfs:comment>Territoire couvert par cette source. Ex: France, Sénégal, Mondial.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- Taux de vaccination dans un contexte géographique -->
    <owl:DatatypeProperty rdf:about="http://www.pacadi.org/these/piponto/module8#hasVaccinationRate">
        <rdfs:domain rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label xml:lang="fr">taux de vaccination</rdfs:label>
        <rdfs:comment>Proportion de la population vaccinée contre la maladie concernée.
        Ex: France COVID-19 2022 = 0.78 (78%). Source SPF.</rdfs:comment>
    </owl:DatatypeProperty>


    <!-- ═══════════════════════════════════════════════════════════
         [M8-EXT-4] NOUVELLES GÉOGRAPHIES (ABox)
         Paris, France, Afrique subsaharienne
         ═══════════════════════════════════════════════════════════ -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#France">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:label xml:lang="fr">France</rdfs:label>
        <rdfs:label xml:lang="en">France</rdfs:label>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">68000000</m8:hasPopulationSize>
        <m8:hasPopulationDensity rdf:datatype="http://www.w3.org/2001/XMLSchema#double">122.0</m8:hasPopulationDensity>
        <m8:hasVaccinationRate rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.78</m8:hasVaccinationRate>
        <rdfs:comment>France métropolitaine. N=68M, densité=122/km². Source : INSEE 2023.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Paris">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:label xml:lang="fr">Paris</rdfs:label>
        <rdfs:label xml:lang="en">Paris</rdfs:label>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2161000</m8:hasPopulationSize>
        <m8:hasPopulationDensity rdf:datatype="http://www.w3.org/2001/XMLSchema#double">20755.0</m8:hasPopulationDensity>
        <m8:hasVaccinationRate rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.81</m8:hasVaccinationRate>
        <m8:isLocatedIn rdf:resource="http://www.pacadi.org/these/piponto/module8#France"/>
        <rdfs:comment>Ville de Paris intra-muros. N=2 161 000, densité=20 755/km² (très élevée).
        Fraction scolaire ≈ 13%. Source : INSEE 2023.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#AfriqueSubsaharienne">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:label xml:lang="fr">Afrique subsaharienne</rdfs:label>
        <rdfs:label xml:lang="en">Sub-Saharan Africa</rdfs:label>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1200000000</m8:hasPopulationSize>
        <rdfs:comment>Région Afrique subsaharienne. Population jeune (médiane 18 ans).
        Accès aux soins limité. Prévalence paludisme élevée.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Montreal">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#GeographicContext"/>
        <rdfs:label xml:lang="fr">Montréal</rdfs:label>
        <rdfs:label xml:lang="en">Montreal</rdfs:label>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2049000</m8:hasPopulationSize>
        <m8:hasPopulationDensity rdf:datatype="http://www.w3.org/2001/XMLSchema#double">4662.0</m8:hasPopulationDensity>
        <rdfs:comment>Ville de Montréal. N=2 049 000. Source : Statistique Canada 2021.</rdfs:comment>
    </owl:NamedIndividual>


    <!-- ═══════════════════════════════════════════════════════════
         [M8-EXT-5] ABOX ENRICHIE
         Groupes de population spécifiques + Sources de données
         ═══════════════════════════════════════════════════════════ -->

    <!-- ── GROUPES DE POPULATION SPÉCIFIQUES PAR VILLE ── -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#SchoolChildren_Paris">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#SchoolChildren"/>
        <rdfs:label xml:lang="fr">Écoliers de Paris</rdfs:label>
        <m8:isLocatedIn rdf:resource="http://www.pacadi.org/these/piponto/module8#Paris"/>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">280000</m8:hasPopulationSize>
        <m8:hasSchoolAgeFraction rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.13</m8:hasSchoolAgeFraction>
        <m8:hasM2PopulationContext rdf:resource="http://www.pacadi.org/these/piponto/module2#Pop_School"/>
        <rdfs:comment>Écoliers Paris 6-15 ans. N ≈ 280 000 (13% de 2.16M).
        Contact scolaire élevé → beta_école > beta_général.
        Source : Ministère Éducation Nationale 2023.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#SchoolChildren_Thies">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#SchoolChildren"/>
        <rdfs:label xml:lang="fr">Écoliers de Thiès</rdfs:label>
        <m8:isLocatedIn rdf:resource="http://www.pacadi.org/these/piponto/module8#Thies"/>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">242000</m8:hasPopulationSize>
        <m8:hasSchoolAgeFraction rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.22</m8:hasSchoolAgeFraction>
        <m8:hasM2PopulationContext rdf:resource="http://www.pacadi.org/these/piponto/module2#Pop_School"/>
        <rdfs:comment>Écoliers Thiès 6-15 ans. N ≈ 242 000 (22% de 1.1M — population jeune).
        Source : ANSD Sénégal 2023.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#ElderlyPop_France">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#ElderlyPopulation"/>
        <rdfs:label xml:lang="fr">Personnes âgées France (65+)</rdfs:label>
        <m8:isLocatedIn rdf:resource="http://www.pacadi.org/these/piponto/module8#France"/>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">14280000</m8:hasPopulationSize>
        <m8:hasElderlyFraction rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.21</m8:hasElderlyFraction>
        <m8:hasM2PopulationContext rdf:resource="http://www.pacadi.org/these/piponto/module2#Pop_Elderly"/>
        <rdfs:comment>Personnes de 65 ans et plus en France. N ≈ 14.28M (21% de 68M).
        Risque élevé de formes graves COVID-19. Source : INSEE 2023.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#GeneralPop_Paris">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#UrbanPopulationGroup"/>
        <rdfs:label xml:lang="fr">Population générale Paris</rdfs:label>
        <m8:isLocatedIn rdf:resource="http://www.pacadi.org/these/piponto/module8#Paris"/>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2161000</m8:hasPopulationSize>
        <m8:hasSchoolAgeFraction rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.13</m8:hasSchoolAgeFraction>
        <m8:hasElderlyFraction rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.17</m8:hasElderlyFraction>
        <m8:hasM2PopulationContext rdf:resource="http://www.pacadi.org/these/piponto/module2#Pop_Urban"/>
        <rdfs:comment>Population générale Paris intra-muros. Très dense (20 755/km²).
        Source : INSEE Recensement 2023.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#RuralPop_Thies">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#RuralPopulationGroup"/>
        <rdfs:label xml:lang="fr">Population rurale région Thiès</rdfs:label>
        <m8:isLocatedIn rdf:resource="http://www.pacadi.org/these/piponto/module8#Thies"/>
        <m8:hasPopulationSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">680000</m8:hasPopulationSize>
        <m8:hasM2PopulationContext rdf:resource="http://www.pacadi.org/these/piponto/module2#Pop_Rural_Africa"/>
        <rdfs:comment>Population rurale région de Thiès. Accès limité aux soins.
        Source : ANSD Sénégal 2023.</rdfs:comment>
    </owl:NamedIndividual>


    <!-- ── SOURCES DE DONNÉES EXTERNES ── -->

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#INSEE_France">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#DemographicDataSource"/>
        <rdfs:label>INSEE — Institut National de la Statistique et des Études Économiques</rdfs:label>
        <m8:hasSourceURL rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://api.insee.fr/catalogue</m8:hasSourceURL>
        <m8:hasDataFormat>JSON, CSV, API REST</m8:hasDataFormat>
        <m8:hasCoverageArea>France</m8:hasCoverageArea>
        <rdfs:comment>Source officielle pour : population France, pyramide des âges, densité, 
        données par commune/département/région. API REST disponible.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#ANSD_Senegal">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#DemographicDataSource"/>
        <rdfs:label>ANSD — Agence Nationale de la Statistique et de la Démographie du Sénégal</rdfs:label>
        <m8:hasSourceURL rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.ansd.sn</m8:hasSourceURL>
        <m8:hasDataFormat>CSV, PDF</m8:hasDataFormat>
        <m8:hasCoverageArea>Sénégal</m8:hasCoverageArea>
        <rdfs:comment>Source officielle démographique Sénégal. Données régions, pyramide des âges,
        projection démographique. Accès CSV/PDF.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#SantePubliqueFrance">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemiologicalDataSource"/>
        <rdfs:label>Santé Publique France (SPF)</rdfs:label>
        <m8:hasSourceURL rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.data.gouv.fr/fr/datasets/donnees-relatives-a-lepidemie-de-covid-19-en-france</m8:hasSourceURL>
        <m8:hasDataFormat>CSV, JSON</m8:hasDataFormat>
        <m8:hasCoverageArea>France</m8:hasCoverageArea>
        <rdfs:comment>Données épidémio France : cas COVID, hospitalisations, décès, vaccination.
        Mise à jour quotidienne. Open data sur data.gouv.fr.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#PNLP_Senegal">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemiologicalDataSource"/>
        <rdfs:label>PNLP — Programme National de Lutte contre le Paludisme (Sénégal)</rdfs:label>
        <m8:hasSourceURL rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.pnlp.sn</m8:hasSourceURL>
        <m8:hasDataFormat>CSV, rapport annuel</m8:hasDataFormat>
        <m8:hasCoverageArea>Sénégal</m8:hasCoverageArea>
        <rdfs:comment>Données paludisme Sénégal : cas par région, mortalité, couverture MII,
        saisonnalité. Données par district sanitaire disponibles.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#POLYMOD_Mossong2008">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#ContactMatrixDataSource"/>
        <rdfs:label>POLYMOD — Mossong et al. (2008)</rdfs:label>
        <m8:hasSourceURL rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://doi.org/10.1371/journal.pmed.0050074</m8:hasSourceURL>
        <m8:hasDataFormat>CSV, matrice</m8:hasDataFormat>
        <m8:hasCoverageArea>Europe (8 pays dont France)</m8:hasCoverageArea>
        <rdfs:comment>Matrices de contacts sociales par tranche d'âge et lieu (école, famille, travail, autres).
        Référence mondiale pour modélisation épidémio structurée par âge.
        Données France disponibles. DOI: 10.1371/journal.pmed.0050074</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Prem2017_ContactMatrices">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#ContactMatrixDataSource"/>
        <rdfs:label>Prem et al. (2017) — Matrices de contacts synthétiques mondiales</rdfs:label>
        <m8:hasSourceURL rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://doi.org/10.1371/journal.pcbi.1005697</m8:hasSourceURL>
        <m8:hasDataFormat>CSV, matrice</m8:hasDataFormat>
        <m8:hasCoverageArea>Mondial (152 pays dont Sénégal)</m8:hasCoverageArea>
        <rdfs:comment>Matrices de contacts synthétiques pour 152 pays. Couvre Sénégal et Afrique.
        Inclut domicile, école, travail, autres. Essentiel pour modélisation Afrique.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#OpenCOVID19_France">
        <rdf:type rdf:resource="http://www.pacadi.org/these/piponto/module8#EpidemiologicalDataSource"/>
        <rdfs:label>OpenCOVID19-fr (GitHub)</rdfs:label>
        <m8:hasSourceURL rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://github.com/opencovid19-fr/data</m8:hasSourceURL>
        <m8:hasDataFormat>CSV, JSON</m8:hasDataFormat>
        <m8:hasCoverageArea>France</m8:hasCoverageArea>
        <rdfs:comment>Données COVID-19 France open source. Mis à jour quotidiennement.
        Idéal pour calibration du paramètre beta sur données réelles françaises.</rdfs:comment>
    </owl:NamedIndividual>


    <!-- ── LIENS GÉOGRAPHIES → SOURCES DE DONNÉES ── -->

    <rdf:Description rdf:about="http://www.pacadi.org/these/piponto/module8#Paris">
        <m8:hasDataSource rdf:resource="http://www.pacadi.org/these/piponto/module8#INSEE_France"/>
        <m8:hasDataSource rdf:resource="http://www.pacadi.org/these/piponto/module8#SantePubliqueFrance"/>
        <m8:hasDataSource rdf:resource="http://www.pacadi.org/these/piponto/module8#POLYMOD_Mossong2008"/>
        <m8:hasDataSource rdf:resource="http://www.pacadi.org/these/piponto/module8#OpenCOVID19_France"/>
    </rdf:Description>

    <rdf:Description rdf:about="http://www.pacadi.org/these/piponto/module8#France">
