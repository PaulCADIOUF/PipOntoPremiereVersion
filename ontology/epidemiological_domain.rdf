        <m8:hasCaseFatalityRate rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.70</m8:hasCaseFatalityRate>
        <m8:isZoonotic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</m8:isZoonotic>
        <rdfs:comment>CFR très élevé (~50-90%) → compartiment D requis dans le modèle.
        Pertinent Afrique de l'Ouest.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- Dengue -->
    <owl:NamedIndividual rdf:about="http://www.pacadi.org/these/piponto/module8#Dengue">
