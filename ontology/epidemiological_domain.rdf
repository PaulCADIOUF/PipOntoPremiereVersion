        <m8:isZoonotic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</m8:isZoonotic>
        <rdfs:comment>Vecteur Aedes aegypti. 4 sérotypes → immunité croisée partielle → SEIRS.
        Pertinent zones tropicales.</rdfs:comment>
    </owl:NamedIndividual>


